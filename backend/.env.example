# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=5000
API_VERSION=v1

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://siwes_user:siwes_password@localhost:5432/siwes_management
DATABASE_URL_TEST=postgresql://siwes_user:siwes_password@localhost:5432/siwes_test

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key
JWT_REFRESH_EXPIRE=30d

# Password Configuration
DEFAULT_PASSWORD=Change@123
BCRYPT_ROUNDS=12

# Frontend URL for links in emails
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail SMTP primary)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=IITMS <your_email@gmail.com>

# Backward-compatible aliases (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# Optional Resend (only used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
RESEND_FROM=

# Redis / Queue / Cache
REDIS_URL=redis://localhost:6379
QUEUE_EMAIL_CONCURRENCY=5
QUEUE_FAILURE_ALERT_THRESHOLD=10
QUEUE_FAILURE_ALERT_WINDOW_MS=60000
QUEUE_DASHBOARD_PATH=/api/v1/queues/dashboard
CACHE_TTL_DASHBOARD=60
CACHE_TTL_REPORTS=120

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Pagination Defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
